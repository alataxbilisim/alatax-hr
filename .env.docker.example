# ALATAX HR — Docker Compose ortam değişkenleri (ÖRNEK)
# Kopyala:  cp .env.docker.example .env
# Bu dosya compose + container env için. Gerçek secret koyma; sadece local örnek değerler.
# Mevcut XAMPP backend/.env dosyasına DOKUNMA — Docker, container environment ile
# DB_HOST/REDIS_HOST vb. override eder (Laravel Dotenv immutable).

# --- Uygulama ---
APP_NAME="ALATAX HR"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_HTTP_PORT=8000

# Frontend SPA URLs (password reset / invitation email links)
FRONTEND_URL_COMPANY=http://localhost:3002
FRONTEND_URL_PORTAL=http://localhost:3003
FRONTEND_URL_SUPERADMIN=http://localhost:3001
FRONTEND_URL=http://localhost:3002

# --- Veritabanı (compose mysql servisi + Laravel DB_*) ---
DB_CONNECTION=mysql
DB_PORT=3306
MYSQL_HOST_PORT=3307
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=alatax_hr
MYSQL_USER=alatax
MYSQL_PASSWORD=secret

# --- Redis (cache + queue + session) ---
REDIS_CLIENT=phpredis
REDIS_HOST_PORT=6379
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# --- Mail (dev: log | Mailtrap için smtp + kendi USERNAME/PASSWORD) ---
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=
# MAIL_PASSWORD=
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@alatax.local"
MAIL_FROM_NAME="${APP_NAME}"
