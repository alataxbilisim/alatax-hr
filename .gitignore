# ALATAX HR — root .gitignore (Laravel backend + pnpm frontend monorepo)

# --- Dependencies ---
node_modules/
**/node_modules/
vendor/
**/vendor/

# --- Environment / secrets ---
.env
.env.*
!.env.example
!.env.*.example
!.env.docker.example
.phpactor.json
auth.json
**/auth.json

# --- Backend (Laravel) ---
backend/node_modules/
backend/public/build
backend/public/hot
backend/public/storage
backend/storage/*.key
backend/storage/pail
backend/storage/logs/*
!backend/storage/logs/.gitignore
backend/storage/framework/cache/*
!backend/storage/framework/cache/.gitignore
!backend/storage/framework/cache/data/
backend/storage/framework/cache/data/*
!backend/storage/framework/cache/data/.gitignore
backend/storage/framework/sessions/*
!backend/storage/framework/sessions/.gitignore
backend/storage/framework/testing/*
!backend/storage/framework/testing/.gitignore
backend/storage/framework/views/*
!backend/storage/framework/views/.gitignore
backend/storage/app/public/*
!backend/storage/app/public/.gitignore
backend/storage/app/private/*
!backend/storage/app/private/.gitignore
backend/bootstrap/cache/*
!backend/bootstrap/cache/.gitignore
backend/database/*.sqlite
backend/database/*.sqlite-journal
backend/database/database.sqlite
.phpunit.result.cache
.phpunit.cache/
Homestead.json
Homestead.yaml

# --- Frontend (Vite / pnpm) ---
frontend/**/dist/
frontend/**/dist-ssr/
frontend/**/build/
frontend/**/.vite/
frontend/**/*.local
*.tsbuildinfo

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- IDE / OS ---
.idea/
.vscode/
!.vscode/extensions.json
.fleet/
.nova/
.zed/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Misc ---
composer.phar
composer-setup.php
*.bak
*.tmp
.cache/
coverage/
.turbo/
