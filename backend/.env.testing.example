APP_NAME="ALATAX HR"
APP_ENV=testing
# APP_KEY — .env / ortamdan miras alınır (boş yazmayın)
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_LEVEL=debug

# KRİTİK: Dev DB (alatax_hr) ile AYNI OLMAMALI
DB_CONNECTION=pgsql
# Docker Compose içinden: postgres | Host makineden: 127.0.0.1
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=alatax_hr_testing
DB_USERNAME=alatax
DB_PASSWORD=secret

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array
BROADCAST_CONNECTION=null

TELESCOPE_ENABLED=false
PULSE_ENABLED=false
NIGHTWATCH_ENABLED=false
